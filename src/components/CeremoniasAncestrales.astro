<!-- Details Modal -->
<div 
  id="details-modal" 
  class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden items-center justify-center p-4 transition-all duration-300 opacity-0"
  aria-hidden="true"
>
  <div 
    id="modal-card" 
    class="w-full max-w-2xl bg-[#FAF5EE] rounded-[2rem] overflow-hidden shadow-2xl relative transform transition-all duration-300 scale-95"
  >
    <!-- Close Button -->
    <button 
      id="close-modal" 
      class="absolute top-4 right-4 bg-black/50 hover:bg-black/70 text-white rounded-full w-9 h-9 flex items-center justify-center transition-colors duration-200 z-10 focus:outline-none"
      aria-label="Close details"
    >
      <i class="fa-solid fa-xmark text-sm"></i>
    </button>

    <!-- Top Image -->
    <div class="relative w-full h-48 sm:h-60 overflow-hidden">
      <img 
        id="modal-image" 
        src="" 
        alt="" 
        class="w-full h-full object-cover"
      />
    </div>

    <!-- Body Content -->
    <div class="p-6 sm:p-8">
      <h3 
        id="modal-title" 
        class="text-[#8E4A38] text-xl sm:text-2xl font-bold mb-3 tracking-tight"
      >
      </h3>
      <p 
        id="modal-desc" 
        class="text-gray-600 text-xs sm:text-sm leading-relaxed mb-6"
      >
      </p>

      <!-- Features Grid -->
      <div 
        id="modal-features" 
        class="grid grid-cols-1 sm:grid-cols-2 gap-3"
      >
        <!-- Dynamic Features will be inserted here -->
      </div>
    </div>
  </div>
</div>

<script>
  interface ModalData {
    title: string;
    description: string;
    image: string;
    features: string[];
  }

  const buttons = document.querySelectorAll('.details-btn');
  const modal = document.getElementById('details-modal');
  const modalCard = document.getElementById('modal-card');
  const modalImage = document.getElementById('modal-image') as HTMLImageElement;
  const modalTitle = document.getElementById('modal-title');
  const modalDesc = document.getElementById('modal-desc');
  const modalFeatures = document.getElementById('modal-features');
  const closeModal = document.getElementById('close-modal');

  const showModal = (data: ModalData) => {
    if (!modal || !modalCard || !modalImage || !modalTitle || !modalDesc || !modalFeatures) return;

    // Populate data
    modalImage.src = data.image;
    modalImage.alt = data.title;
    modalTitle.textContent = data.title;
    modalDesc.textContent = data.description;

    // Build features grid
    modalFeatures.innerHTML = '';
    data.features.forEach((feat) => {
      const item = document.createElement('div');
      item.className = 'flex items-center gap-2.5 bg-white shadow-sm px-4 py-3.5 rounded-2xl text-[11px] sm:text-xs text-gray-800 border border-gray-100/50';
      item.innerHTML = `<span class="text-[#8F5547] text-sm font-semibold">✓</span> <span class="font-semibold">${feat}</span>`;
      modalFeatures.appendChild(item);
    });

    // Make visible and set display
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    
    // Force browser reflow to register transition classes
    void modal.offsetWidth;

    // Start transition
    modal.classList.remove('opacity-0');
    modalCard.classList.remove('scale-95');
    modalCard.classList.add('scale-100');

    // Prevent background scrolling without layout shift
    const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
    document.body.style.paddingRight = scrollbarWidth + 'px';
    document.body.style.overflow = 'hidden';
  };

  const hideModal = () => {
    if (!modal || !modalCard) return;

    // Transition out
    modal.classList.add('opacity-0');
    modalCard.classList.remove('scale-100');
    modalCard.classList.add('scale-95');

    // Wait for transition before fully hiding
    setTimeout(() => {
      modal.classList.remove('flex');
      modal.classList.add('hidden');
      document.body.style.overflow = '';
      document.body.style.paddingRight = '';
    }, 300);
  };

  // Add click handlers
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const rawDetails = btn.getAttribute('data-details');
      if (rawDetails) {
        showModal(JSON.parse(rawDetails));
      }
    });
  });

  if (closeModal) {
    closeModal.addEventListener('click', hideModal);
  }

  // Click outside to close
  if (modal) {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        hideModal();
      }
    });
  }

  // Close on Escape key press
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
      hideModal();
    }
  });
</script>
